################
### MONITOR  ###
################
monitor=,1920x1080@60,auto,1

################
### AUTOSTART ###
################
exec-once = waybar
exec-once = dunst
exec-once = swaybg -i /home/show/Pictures/wall.jpg -m stretch

################
### ENV VARS ###
################
env = WLR_NO_HARDWARE_CURSORS,1
env = WLR_RENDERER_ALLOW_SOFTWARE,1
env = XDG_CURRENT_DESKTOP,Hyprland
env = XDG_SESSION_TYPE,wayland
env = XDG_SESSION_DESKTOP,Hyprland
env = QT_QPA_PLATFORM,wayland
env = XCURSOR_SIZE,24

################
### INPUT    ###
################
input {
    kb_layout = es
    follow_mouse = 1
    sensitivity = 0

    touchpad {
        natural_scroll = no
    }

    sensitivity = 0
    repeat_rate = 25
    repeat_delay = 600
}

################
### APARIENCIA ###
################
general {
    gaps_in = 4
    gaps_out = 8
    border_size = 2
    col.active_border   = rgba(d8a657ff) rgba(a9b665ff) 45deg
    col.inactive_border = rgba(3c3836aa)
    layout = dwindle
}

decoration {
    rounding = 10
    active_opacity   = 1.0
    inactive_opacity = 0.93
    blur {
        enabled  = true
        size     = 8
        passes   = 2
    }
}

animations {
    enabled = true
    bezier = expo, 0.16, 1, 0.3, 1
    animation = windows,    1, 6, expo, slide
    animation = windowsOut, 1, 6, expo, slide
    animation = fade,       1, 8, expo
    animation = workspaces, 1, 5, expo, slidevert
}

dwindle {
    pseudotile     = true
    preserve_split = true
}

misc {
    disable_hyprland_logo    = true
    disable_splash_rendering = true
    force_default_wallpaper  = 0
}

################
### LAYERRULES ###
################
blurls = waybar

################
### KEYBINDS ###
################
$mod = ALT
bind = $mod,       Return, exec,           foot
bind = $mod,       Space,  exec,           wofi --show drun
bind = $mod SHIFT, S,      exec,           grim -g "$(slurp)" ~/screenshot_$(date +%s).png
bind = $mod,       Q,      killactive
bind = $mod,       F,      fullscreen,     0
bind = $mod SHIFT, F,      togglefloating
bind = $mod,       M,      exit
bind = $mod, left,  movefocus, l
bind = $mod, right, movefocus, r
bind = $mod, up,    movefocus, u
bind = $mod, down,  movefocus, d
bind = $mod, 1, workspace, 1
bind = $mod, 2, workspace, 2
bind = $mod, 3, workspace, 3
bind = $mod, 4, workspace, 4
bind = $mod, 5, workspace, 5
bind = $mod SHIFT, 1, movetoworkspace, 1
bind = $mod SHIFT, 2, movetoworkspace, 2
bind = $mod SHIFT, 3, movetoworkspace, 3
bind = $mod SHIFT, 4, movetoworkspace, 4
bind = $mod SHIFT, 5, movetoworkspace, 5
bindm = $mod, mouse:272, movewindow
bindm = $mod, mouse:273, resizewindow
bind = $mod SHIFT, R, exec, hyprctl reload
bind = $mod SHIFT, E, exec, wlogout -b 3 -s /home/show/.config/wlogout/style.css -l /home/show/.config/wlogout/layout
#exec-once = /usr/bin/spice-vdagent
exec-once = DISPLAY=:0 /usr/bin/spive-vdagent
exec-once = ~/clipboard-bridge-v2.sh
exec-once = dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
exec-once = systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
exec-once = spice-vdagent
